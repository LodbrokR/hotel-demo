---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bienvenidos">
	<!-- Hero -->
	<section class="relative h-[85vh] w-full flex flex-col justify-end pb-24 px-6 md:px-16 overflow-hidden">
		<!-- Image placeholder Banana -->
		<div class="absolute inset-0 z-0">
			<div class="absolute inset-0 bg-black/20 z-10"></div>
			<img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?q=80&w=2000&auto=format&fit=crop" alt="Hotel Boutique en la Patagonia" class="w-full h-full object-cover object-center" />
		</div>
		<div class="relative z-20 max-w-4xl text-white">
			<p class="text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-medium drop-shadow-md">Puerto Varas, Chile</p>
			<h1 class="text-5xl md:text-7xl font-light mb-8 drop-shadow-lg leading-tight">Desconecta para <br/><span class="font-semibold">conectar.</span></h1>
			
			<!-- Booking Bar -->
			<form id="reservaForm" class="bg-white/95 backdrop-blur-xl p-4 md:p-6 rounded-none md:rounded-full shadow-2xl flex flex-col md:flex-row items-center gap-4 text-brand-900 w-full md:w-max relative">
				<div class="flex flex-col px-4 w-full md:w-auto border-b md:border-b-0 md:border-r border-brand-100 pb-2 md:pb-0">
					<label class="text-xs uppercase tracking-widest text-brand-500 font-semibold mb-1">Llegada</label>
					<input type="date" name="Llegada" class="bg-transparent outline-none font-medium text-sm" value="2026-05-01">
				</div>
				<div class="flex flex-col px-4 w-full md:w-auto border-b md:border-b-0 md:border-r border-brand-100 pb-2 md:pb-0">
					<label class="text-xs uppercase tracking-widest text-brand-500 font-semibold mb-1">Salida</label>
					<input type="date" name="Salida" class="bg-transparent outline-none font-medium text-sm" value="2026-05-04">
				</div>
				<div class="flex flex-col px-4 w-full md:w-auto">
					<label class="text-xs uppercase tracking-widest text-brand-500 font-semibold mb-1">Huéspedes</label>
					<select name="Huéspedes" class="bg-transparent outline-none font-medium text-sm cursor-pointer">
						<option>2 Adultos</option>
						<option>1 Adulto</option>
						<option>Familia (4)</option>
					</select>
				</div>
				<button type="submit" id="submitBtn" class="w-full md:w-auto bg-brand-900 text-white px-8 py-4 rounded-full uppercase tracking-widest text-sm font-semibold hover:bg-brand-600 transition-colors mt-2 md:mt-0 whitespace-nowrap">
					Consultar
				</button>
				<input type="hidden" name="_subject" value="Nueva consulta de reserva de Hotel">
				<input type="hidden" name="_captcha" value="false">
				
				<!-- Success Message (Absolute positioned above or below bar) -->
				<div id="formStatus" class="hidden absolute -bottom-12 left-0 w-full text-center text-sm font-semibold text-white drop-shadow-md bg-emerald-500/90 py-2 rounded-full backdrop-blur-md">
					¡Consulta enviada! Te responderemos pronto.
				</div>
			</form>
		</div>
	</section>

	<!-- Bento Experiences -->
	<section class="py-24 max-w-7xl mx-auto px-6">
		<div class="text-center mb-16">
			<h2 class="text-3xl font-light mb-4">La Experiencia Austral</h2>
			<div class="w-16 h-px bg-brand-500 mx-auto"></div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-12 gap-4 auto-rows-[300px]">
			
			<div class="md:col-span-8 row-span-2 relative group overflow-hidden bg-white">
				<div class="absolute inset-0 transition-transform duration-1000 group-hover:scale-105">
					<img src="https://images.unsplash.com/photo-1618773928121-c32242e63f39?q=80&w=1000&auto=format&fit=crop" alt="Suite Panorámica" class="w-full h-full object-cover object-center" />
				</div>
				<div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
				<div class="absolute bottom-0 left-0 p-8 text-white w-full">
					<p class="uppercase tracking-widest text-xs mb-2">Alojamiento</p>
					<div class="flex justify-between items-end">
						<h3 class="text-3xl font-light">Suites Panorámicas</h3>
						<span class="hidden md:inline-block border border-white px-6 py-2 uppercase tracking-widest text-xs hover:bg-white hover:text-brand-900 transition-colors cursor-pointer">Ver más</span>
					</div>
				</div>
			</div>

			<div class="md:col-span-4 relative group overflow-hidden bg-brand-900 text-white p-10 flex flex-col justify-center">
				<h3 class="text-2xl font-light mb-4">Spa del Bosque</h3>
				<p class="text-brand-100/70 text-sm leading-relaxed mb-6">Aguas termales, masajes con piedras calientes y sauna húmedo rodeado de naturaleza.</p>
				<a href="#" class="text-brand-500 uppercase tracking-widest text-xs font-semibold hover:text-white transition-colors">Descubrir Spa &rarr;</a>
			</div>

			<div class="md:col-span-4 relative group overflow-hidden">
				<div class="absolute inset-0 transition-transform duration-1000 group-hover:scale-105">
					<img src="https://images.unsplash.com/photo-1533777857889-4be7c70b33f7?q=80&w=1000&auto=format&fit=crop" alt="Gastronomía Local" class="w-full h-full object-cover object-center" />
				</div>
				<div class="absolute inset-0 bg-black/30"></div>
				<div class="absolute inset-0 flex flex-col items-center justify-center text-white p-6 text-center">
					<h3 class="text-xl font-medium mb-2">Gastronomía Local</h3>
					<p class="text-sm">Sabores del sur.</p>
				</div>
			</div>

		</div>
	</section>
</Layout>

<script>
	const form = document.getElementById('reservaForm') as HTMLFormElement;
	const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
	const formStatus = document.getElementById('formStatus');

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			const originalText = submitBtn.innerText;
			submitBtn.innerText = 'Enviando...';
			submitBtn.disabled = true;

			try {
				const formData = new FormData(form);
				const res = await fetch('https://formsubmit.co/ajax/lmedina.web@gmail.com', {
					method: 'POST',
					headers: {
						'Accept': 'application/json'
					},
					body: formData
				});

				if (res.ok) {
					form.reset();
					formStatus?.classList.remove('hidden');
					setTimeout(() => {
						formStatus?.classList.add('hidden');
					}, 5000);
				} else {
					alert('Hubo un error al procesar la consulta. Inténtalo nuevamente.');
				}
			} catch (error) {
				alert('Hubo un error de conexión.');
			} finally {
				submitBtn.innerText = originalText;
				submitBtn.disabled = false;
			}
		});
	}
</script>
