---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es-CL" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Hotel Boutique en el sur de Chile. Naturaleza y confort." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title} | Refugio Austral</title>
	</head>
	<body class="font-['Inter'] bg-brand-50 text-brand-900 antialiased selection:bg-brand-500 selection:text-white flex flex-col min-h-screen">
		<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-brand-100 transition-all">
			<div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
				<a href="/" class="flex flex-col items-center group">
					<span class="font-light text-2xl tracking-[0.2em] text-brand-900 uppercase">Refugio</span>
					<span class="font-bold text-xs tracking-[0.4em] text-brand-500 uppercase">Austral</span>
				</a>
				<nav class="hidden md:flex items-center gap-10">
					<ul class="flex items-center gap-8 text-sm font-medium text-brand-600 uppercase tracking-widest">
						<li><a href="/" class="hover:text-brand-900 transition-colors">Hotel</a></li>
						<li><a href="/habitaciones" class="hover:text-brand-900 transition-colors">Habitaciones</a></li>
						<li><a href="/experiencias" class="hover:text-brand-900 transition-colors">Experiencias</a></li>
					</ul>
					<a href="/reservas" class="bg-brand-900 hover:bg-brand-600 text-white px-8 py-3 font-medium transition-all tracking-widest text-sm uppercase shadow-lg shadow-brand-900/10">Reservar</a>
				</nav>
			</div>
		</header>
		<main class="flex-grow pt-24">
			<slot />
		</main>
		<footer class="bg-brand-900 text-brand-100 py-16 mt-auto">
			<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-12 text-center md:text-left">
				<div>
					<span class="font-light text-2xl tracking-[0.2em] uppercase block">Refugio</span>
					<span class="font-bold text-xs tracking-[0.4em] text-brand-500 uppercase block mb-6">Austral</span>
					<p class="text-sm text-brand-100/70 max-w-xs mx-auto md:mx-0">Donde el bosque nativo se encuentra con el diseño contemporáneo en la Patagonia Chilena.</p>
				</div>
				<div>
					<h4 class="font-medium tracking-widest uppercase mb-4 text-white text-sm">Contacto</h4>
					<p class="text-sm text-brand-100/70 mb-2">Ruta 225, Km 45, Puerto Varas</p>
					<p class="text-sm text-brand-100/70 mb-2">+56 65 234 5678</p>
					<p class="text-sm text-brand-100/70">reservas@refugioaustral.cl</p>
				</div>
				<div>
					<h4 class="font-medium tracking-widest uppercase mb-4 text-white text-sm">Políticas</h4>
					<ul class="text-sm text-brand-100/70 space-y-2">
						<li><a href="#" class="hover:text-white transition-colors">Términos y Condiciones</a></li>
						<li><a href="#" class="hover:text-white transition-colors">Políticas de Cancelación</a></li>
					</ul>
				</div>
			</div>
		</footer>
	</body>
</html>
